[attr]lock filter=lfs diff=lfs merge=binary -text lockable
[attr]lockonly lockable
[attr]lfs filter=lfs diff=lfs merge=binary -text
[attr]lfstext filter=lfs diff=lfstext merge=lfstext -text
# Source files — LF in repo, CRLF on Windows checkout
*.cpp    text eol=crlf
*.h      text eol=crlf
*.cs     text eol=crlf
*.ini    text eol=crlf
*.json   text eol=crlf
*.md     text eol=crlf

# Unreal Engine file types.
*.uasset lock
*.umap   lock
# Steam Audio files
*.phononscene lfs
*.probebox lfs
*.probebatch lfs
*.bakedsources lfs
# Binaries
*.exe lfs
*.dll lfs
*.rcc lfs
#Icons
*.png  lfs
*.jpg  lfs
*.jpeg lfs
*.tga  lfs
*.exr  lfs
*.ico  lfs
#FMOD 
*.wav  lfs 
*.mp3  lfs 
